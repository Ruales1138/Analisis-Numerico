    "import numpy as np\n",
    "\n",
    "A = np.array([[-3,2,1],[6,-8,-2],[1,-1,-2]], float)\n",
    "b = np.array([2,1,3], float)\n",
    "n = len(b)\n",
    "\n",
    "for i in range(n):\n",
    "    for j in range(i+1, n):\n",
    "        factor = A[j,i] / A[i,i]\n",
    "        print(factor)\n",
    "        A[j, i:n] = A[j, i:n] - factor*A[i, i:n]\n",
    "        print(A)"
   ]
